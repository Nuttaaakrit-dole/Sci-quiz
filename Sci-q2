  { cat: "โลกและการเปลี่ยนแปลง", q: "ปรากฏการณ์ 'ลมทะเล' (ลมพัดจากทะเลเข้าฝั่ง) เกิดขึ้นในเวลาใด และเกิดจากสาเหตุใด?", choices: ["เกิดตอนกลางวัน เพราะพื้นดินร้อนเร็วกว่าพื้นน้ำ อากาศเหนือพื้นดินจึงลอยตัวสูงขึ้น", "เกิดตอนกลางคืน เพราะพื้นน้ำเย็นเร็วกว่าพื้นดิน", "เกิดตอนกลางวัน เพราะพื้นน้ำดูดซับความร้อนได้ดีกว่าพื้นดิน", "เกิดตอนกลางคืน เพราะมีอิทธิพลจากแรงดึงดูดของดวงจันทร์"], a: 0, exp: "ตอนกลางวัน ดินรับความร้อนได้เร็วกว่าน้ำ อากาศเหนือผิวดินจึงร้อนและลอยตัวขึ้น อากาศเย็นจากผิวน้ำทะเลจึงพัดเข้ามาแทนที่ เรียกว่าลมทะเล" },
  { cat: "สิ่งมีชีวิตและสิ่งแวดล้อม", q: "พืชใบเลี้ยงคู่และพืชใบเลี้ยงเดี่ยว มีความแตกต่างกันในเรื่องใดที่เห็นได้ชัดเจนที่สุด?", choices: ["ระบบรากและเส้นใบ", "การสังเคราะห์ด้วยแสง", "การสืบพันธุ์แบบไม่อาศัยเพศ", "การตอบสนองต่อแสง"], a: 0, exp: "พืชใบเลี้ยงคู่มีรากแก้วและเส้นใบเป็นร่างแห ส่วนพืชใบเลี้ยงเดี่ยวมีรากฝอยและเส้นใบขนาน (ส่วนการสังเคราะห์ด้วยแสงมีเหมือนกันทั้งคู่)" }
];

let state = {
  screen: 'login', // login, quiz, result
  studentName: '',
  studentId: '',
  questions: [], 
  answers: [], 
  checked: [], 
  current: 0
};

// สุ่ม Array
function shuffleArray(arr) {
  let newArr = arr.slice();
  for (let i = newArr.length - 1; i > 0; i--) {
    let j = Math.floor(Math.random() * (i + 1));
    let temp = newArr[i];
    newArr[i] = newArr[j];
    newArr[j] = temp;
  }
  return newArr;
}

// เริ่มทำแบบทดสอบ
function startApp() {
  const nameInput = document.getElementById('s_name').value;
  const idInput = document.getElementById('s_id').value;
  
  if (nameInput.trim() === '') {
    alert('กรุณากรอกชื่อ-นามสกุลก่อนเข้าสอบครับ');
    return;
  }
  
  state.studentName = nameInput;
  state.studentId = idInput || 'สกร. อำเภอโนนสัง';
  document.getElementById('subtitle-text').innerText = 'ผู้เข้าสอบ: ' + state.studentName;
  
  let shuffledDB = shuffleArray(database);
  state.questions = [];
  
  for (let i = 0; i < shuffledDB.length; i++) {
    let q = shuffledDB[i];
    let correctText = q.choices[q.a];
    let newChoices = shuffleArray(q.choices);
    let newCorrectIndex = newChoices.indexOf(correctText);
    
    state.questions.push({
      cat: q.cat,
      q: q.q,
      exp: q.exp,
      choices: newChoices,
      correctAnswer: newCorrectIndex
    });
  }
  
  state.answers = new Array(state.questions.length).fill(null);
  state.checked = new Array(state.questions.length).fill(false);
  state.current = 0;
  state.screen = 'quiz';
  
  renderApp();
}

function renderApp() {
  const app = document.getElementById('app');
  if (state.screen === 'login') {
    app.innerHTML = `
      <div class="card" style="text-align: center; padding: 40px 20px;">
        <div style="font-size: 60px; margin-bottom: 10px;">🧪</div>
        <h2 style="color: var(--primary); margin-bottom: 10px;">ข้อมูลผู้เข้าสอบ (ชุดที่ 2)</h2>
        <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;">ระบบจะสุ่มข้อสอบและสุ่มตัวเลือกใหม่ทุกครั้ง</p>
        <div class="inp-group">
          <label class="inp-label">ชื่อ-นามสกุล (บังคับ)</label>
          <input type="text" id="s_name" class="inp-text" placeholder="ระบุชื่อและนามสกุล">
        </div>
        <div class="inp-group">
          <label class="inp-label">รหัสนักศึกษา / สังกัด</label>
          <input type="text" id="s_id" class="inp-text" value="สกร. อำเภอโนนสัง">
        </div>
        <button class="btn btn-primary" style="margin-top: 10px;" onclick="startApp()">เริ่มทำแบบทดสอบ 🚀</button>
      </div>
    `;
  } 
  else if (state.screen === 'quiz') {
    let total = state.questions.length;
    let curr = state.current;
    let q = state.questions[curr];
    let ans = state.answers[curr];
    let isChecked = state.checked[curr];
    let pct = Math.round(((curr + 1) / total) * 100);
    
    let letters = ['A', 'B', 'C', 'D'];
    let choicesHTML = '';
    for (let i = 0; i < 4; i++) {
      let cssClass = 'choice';
      if (isChecked) {
        if (i === q.correctAnswer) cssClass += ' correct';
        else if (i === ans && ans !== q.correctAnswer) cssClass += ' wrong';
      } else {
        if (i === ans) cssClass += ' selected';
      }
      
      let disabledAttr = isChecked ? 'disabled' : '';
      choicesHTML += `<button class="${cssClass}" ${disabledAttr} onclick="selectAnswer(${i})">
                        <div class="c-let">${letters[i]}</div>
                        <div>${q.choices[i]}</div>
                      </button>`;
    }
    
    let fbHTML = '';
    if (isChecked) {
      if (ans === q.correctAnswer) {
        fbHTML = `<div class="feedback ok">✅ <strong>ถูกต้อง!</strong><div class="fb-explain">💡 ${q.exp}</div></div>`;
      } else {
        fbHTML = `<div class="feedback no">❌ <strong>ยังไม่ถูกต้อง</strong> — คำตอบที่ถูกคือ: <strong>${q.choices[q.correctAnswer]}</strong><div class="fb-explain">💡 ${q.exp}</div></div>`;
      }
    }
    
    let navHTML = '';
    let btnPrev = curr > 0 ? `<button class="btn btn-secondary" onclick="goPrev()">← ย้อนกลับ</button>` : `<div style="width:48%"></div>`;
    let btnNext = '';
    
    if (isChecked) {
      if (curr === total - 1) {
        btnNext = `<button class="btn btn-primary" onclick="showResult()">ประมวลผลคะแนน 🏆</button>`;
      } else {
        btnNext = `<button class="btn btn-primary" onclick="goNext()">ถัดไป →</button>`;
      }
    } else {
      let dis = ans === null ? 'disabled' : '';
      btnNext = `<button class="btn btn-primary" ${dis} onclick="checkAnswer()">ตรวจคำตอบ ✓</button>`;
    }
    navHTML = `<div class="nav-buttons">${btnPrev}${btnNext}</div>`;
    
    let dotsHTML = '<div class="dot-nav">';
    for (let i = 0; i < total; i++) {
      let dClass = 'dot';
      if (i === curr) dClass += ' active';
      else if (state.checked[i]) {
        dClass += (state.answers[i] === state.questions[i].correctAnswer) ? ' ok' : ' no';
      }
      dotsHTML += `<button class="${dClass}" onclick="jumpTo(${i})">${i+1}</button>`;
    }
    dotsHTML += '</div>';

    app.innerHTML = `
      <div class="card" style="padding: 16px 20px;">
        <div class="prog-text">
          <span>ข้อที่ ${curr + 1} จาก ${total}</span>
          <span>ตอบแล้ว ${state.answers.filter(a => a !== null).length} ข้อ</span>
        </div>
        <div class="prog-bar"><div class="prog-fill" style="width: ${pct}%"></div></div>
      </div>
      
      <div class="card">
        <div class="q-badge">${q.cat}</div>
        <div class="q-text"><span class="q-num-circle">${curr + 1}</span> ${q.q}</div>
        <div class="choices">${choicesHTML}</div>
        ${fbHTML}
        ${navHTML}
      </div>
      ${dotsHTML}
    `;
  }
  else if (state.screen === 'result') {
    let total = state.questions.length;
    let score = 0;
    let categoryStats = {};
    
    for (let i = 0; i < total; i++) {
      let q = state.questions[i];
      if (!categoryStats[q.cat]) categoryStats[q.cat] = { t: 0, c: 0 };
      categoryStats[q.cat].t++;
      
      if (state.answers[i] === q.correctAnswer) {
        score++;
        categoryStats[q.cat].c++;
      }
    }
    
    let pct = Math.round((score / total) * 100);
    let grade = '', gClass = '', msg = '';
    
    if (pct >= 80) { grade = 'ดีมาก (A)'; gClass = 'grade-A'; msg = 'ยอดเยี่ยม! ทักษะการวิเคราะห์วิทยาศาสตร์คุณดีมาก'; }
    else if (pct >= 60) { grade = 'ดี (B)'; gClass = 'grade-B'; msg = 'ทำได้ดีมากครับ ตอบคำถามเชิงประยุกต์ได้ดี'; }
    else if (pct >= 50) { grade = 'พอใช้ (C)'; gClass = 'grade-C'; msg = 'ผ่านเกณฑ์แล้ว แต่อาจต้องทบทวนหลักการเชิงลึกอีกนิด'; }
    else { grade = 'ต้องปรับปรุง (D)'; gClass = 'grade-D'; msg = 'ข้อสอบชุดนี้มีความซับซ้อนขึ้น ลองอ่านเฉลยและสู้ใหม่อีกครั้งนะครับ'; }
    
    let weak = [];
    for (let cat in categoryStats) {
      if (categoryStats[cat].t > 0 && (categoryStats[cat].c / categoryStats[cat].t) <= 0.5) {
        weak.push(cat);
      }
    }
    
    let fbMsg = weak.length > 0 
      ? `📉 <strong>ระบบวิเคราะห์จุดอ่อน:</strong> คุณมีข้อผิดพลาดบ่อยในสาระ <strong>${weak.join(' และ ')}</strong> แนะนำให้ทบทวนเนื้อหาส่วนนี้เพิ่มเติมครับ`
      : `✨ <strong>ระบบวิเคราะห์:</strong> เก่งมากครับ! คุณสามารถประยุกต์ความรู้วิทยาศาสตร์ผ่านเกณฑ์ในทุกสาระการเรียนรู้`;

    let today = new Date();
    let dateString = today.getDate() + '/' + (today.getMonth()+1) + '/' + (today.getFullYear()+543);

    let reviewHTML = '<div class="card" style="margin-top:20px"><div class="review-title">📋 ตรวจสอบคำตอบอย่างละเอียด (ชุดที่ 2)</div>';
    for (let i = 0; i < total; i++) {
      let q = state.questions[i];
      let isCorr = (state.answers[i] === q.correctAnswer);
      let userText = state.answers[i] !== null ? q.choices[state.answers[i]] : '(ไม่ได้ตอบ)';
      let icon = isCorr ? '✓' : '✗';
      let iconCls = isCorr ? 'ri-ok' : 'ri-no';
      
      reviewHTML += `
        <div class="review-item">
          <div class="r-q"><span class="ri-tick ${iconCls}">${icon}</span> ข้อ ${i+1}: ${q.q}</div>
          <div class="r-a" style="color:var(--text-muted)">คุณตอบ: ${userText}</div>
          <div class="r-a" style="color:var(--green); font-weight:600;">เฉลย: ${q.choices[q.correctAnswer]}</div>
          <div class="r-exp">💡 ${q.exp}</div>
        </div>
      `;
    }
    reviewHTML += '</div>';

    app.innerHTML = `
      <div class="card" style="text-align:center; padding:32px 20px;">
        <div class="cert-header">รายงานผลการทดสอบวิทยาศาสตร์ (ชุดที่ 2)</div>
        <div class="cert-name">คุณ ${state.studentName}</div>
        <div class="cert-meta">รหัส/สังกัด: ${state.studentId} | วันที่สอบ: ${dateString}</div>
        
        <div style="font-size:60px; margin: 10px 0;">${pct >= 50 ? '🏆' : '📖'}</div>
        <div class="score-big">${score}</div>
        <div class="score-denom">จาก ${total} ข้อ (${pct}%)</div>
        <div style="margin: 16px 0;"><span class="grade-pill ${gClass}">${grade}</span></div>
        <div style="color:var(--text-muted); margin-bottom: 24px;">${msg}</div>
        
        <div class="feedback-box">${fbMsg}</div>
        
        <div class="grid-stats">
          <div class="stat-box"><div class="stat-num" style="color:var(--green)">${score}</div><div class="slbl">ตอบถูก</div></div>
          <div class="stat-box"><div class="stat-num" style="color:var(--red)">${total - score}</div><div class="slbl">ตอบผิด</div></div>
          <div class="stat-box"><div class="stat-num" style="color:var(--primary)">${pct}%</div><div class="slbl">คะแนน</div></div>
        </div>
        
        <button class="btn btn-primary" onclick="location.reload()">🔄 ทำแบบทดสอบชุดที่ 2 อีกครั้ง</button>
      </div>
      ${reviewHTML}
    `;
  }
}

function selectAnswer(index) {
  if (state.checked[state.current]) return;
  state.answers[state.current] = index;
  renderApp();
}

function checkAnswer() {
  if (state.answers[state.current] === null) return;
  state.checked[state.current] = true;
  renderApp();
}

function goNext() {
  if (state.current < state.questions.length - 1) {
    state.current++;
    renderApp();
  }
}

function goPrev() {
  if (state.current > 0) {
    state.current--;
    renderApp();
  }
}

function jumpTo(index) {
  state.current = index;
  renderApp();
}

function showResult() {
  state.screen = 'result';
  renderApp();
}

// Initial Call
renderApp();
</script>
</body>
</html>
